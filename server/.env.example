PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/foliomind
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123!

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# AI provider switch
# Use "ollama" for local unlimited usage.
# Use "openai_compatible" for OpenAI/Groq/OpenRouter style APIs.
AI_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
# OpenAI-compatible settings (optional)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
GITHUB_TOKEN=

# LinkedIn sync settings
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/rohanvaradaraju/
# Optional if your environment needs explicit Chrome/Chromium path:
PUPPETEER_EXECUTABLE_PATH=

CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
ALLOWED_ORIGINS=http://10.204.9.148:5173,http://10.204.9.148:5174
